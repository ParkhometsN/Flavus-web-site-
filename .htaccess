# .htaccess для Reg.ru хостинга (flavus-barbershop.ru)

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Редирект на HTTPS и правильный домен
    RewriteCond %{HTTPS} off [OR]
    RewriteCond %{HTTP_HOST} !^flavus-barbershop\.ru$ [NC]
    RewriteRule ^(.*)$ https://flavus-barbershop.ru/$1 [R=301,L]

    # index.html -> корень
    RewriteRule ^index\.html$ / [R=301,L]
</IfModule>

# Запрет на просмотр папок
Options -Indexes

# Страница 404
ErrorDocument 404 /404.html

# Главный файл по умолчанию
DirectoryIndex index.html index.php