# Защита административной панели
# Вход в админку должен происходить только через проверенную аутентификацию приложения
# Базовый доступ разрешён, но конфиги и скрипт обновления закрыты

<IfModule mod_authz_core.c>
    Require all granted
</IfModule>
<IfModule !mod_authz_core.c>
    Order allow,deny
    Allow from all
</IfModule>

# Закрыть конфигурационные файлы и обновление
<FilesMatch "^(conf|lang)\.ini$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</FilesMatch>

<Files "update.php">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</Files>

Options -Indexes
